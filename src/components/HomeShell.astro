---
import {
  actionDemos,
  aboutHero,
  aboutQuote,
  calloutItems,
  codeDemos,
  contactDetailRows,
  contactHero,
  contactInfoPanel,
  contactLinks,
  contactNotes,
  contactPreferences,
  contactRows,
  contactStatusChips,
  contactTimeline,
  detailRows,
  featureNotes,
  heroStats,
  inlineLinks,
  profileCards,
  readingPanel,
  rhythmItems,
  sectionHeadings,
  tabs,
  themeConfig,
  timelineItems,
  typographyChecks,
  type PanelKey,
} from "@/data/siteContent";

interface Props {
  initialActive?: PanelKey;
}

const { initialActive = "about" } = Astro.props;

const externalLinkAttributes = (href: string) =>
  href.startsWith("http") ? { target: "_blank", rel: "noopener noreferrer" } : {};
---

<main class="kawaii-shell page-shell" data-home-shell data-active={initialActive}>
  <header class="topbar">
    <button class="theme-toggle" type="button" data-theme-toggle aria-label="切换深色模式" aria-pressed="false">
      <svg class="moon-icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M19.5 14.5A8.5 8.5 0 0 1 9.5 4.5a8.5 8.5 0 1 0 10 10Z" />
      </svg>
    </button>

    <nav class="topnav" aria-label="页面切换">
      <span class="topnav-indicator" aria-hidden="true"></span>
      {tabs.map((tab) => (
        <a
          href={tab.href}
          data-tab-target={tab.key}
          aria-current={tab.key === initialActive ? "page" : undefined}
        >
          {tab.label}
        </a>
      ))}
    </nav>
  </header>

  <section class="card-stage" aria-live="polite">
    <div class="card-viewport">
      <div class="card-track">
        <div class="card-panel">
          <article class="sample-card" data-card-panel="about">
            <div class="sample-inner">
              <section class="sample-hero">
                <p class="sample-kicker">{aboutHero.kicker}</p>
                <h1 class="sample-title">{aboutHero.title}</h1>
                <p class="sample-copy">{aboutHero.copy}</p>

                <div class="sample-card-accent" aria-label="标签示例">
                  {aboutHero.tags?.map((tag) => (
                    <span class="sample-chip" lang={tag.lang}>{tag.text}</span>
                  ))}
                </div>

                <div class="hero-stats" aria-label="基础信息示例">
                  {heroStats.map(([label, value]) => (
                    <div class="hero-stat">
                      <span>{label}</span>
                      <strong>{value}</strong>
                    </div>
                  ))}
                </div>
              </section>

              <section class="demo-section">
                <div class="section-heading">
                  <h2>{sectionHeadings.profileCards.title}</h2>
                  <p>{sectionHeadings.profileCards.description}</p>
                </div>

                <div class="demo-grid demo-grid--four">
                  {profileCards.map((item) => (
                    <section class="demo-block">
                      <h3>{item.title}</h3>
                      <p lang={item.lang}>{item.text}</p>
                    </section>
                  ))}
                </div>
              </section>

              <section class="demo-section demo-section--split">
                <blockquote class="demo-quote">
                  {aboutQuote}
                </blockquote>

                <div class="demo-panel">
                  <h2>{readingPanel.title}</h2>
                  <p>{readingPanel.body}</p>
                  <ul class="demo-list">
                    {rhythmItems.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
              </section>

              <section class="demo-section">
                <div class="section-heading">
                  <h2>{sectionHeadings.typography.title}</h2>
                  <p>{sectionHeadings.typography.description}</p>
                </div>

                <div class="demo-table" aria-label="字体和换行测试">
                  {typographyChecks.map((item) => (
                    <div>
                      <span>{item.label}</span>
                      <strong lang={item.lang}>{item.value}</strong>
                    </div>
                  ))}
                </div>
              </section>

              <section class="demo-section demo-section--split">
                <div class="demo-code" aria-label="代码片段示例">
                  <div class="demo-code-head">
                    <span>{codeDemos.profile.filename}</span>
                    <button type="button" data-copy-button aria-label="复制代码" aria-live="polite">复制</button>
                  </div>
                  <pre><code>{codeDemos.profile.code}</code></pre>
                </div>

                <div class="demo-notices">
                  {calloutItems.map((item) => <p>{item}</p>)}
                </div>
              </section>

              <section class="demo-section">
                <div class="section-heading">
                  <h2>{sectionHeadings.linksAndButtons.title}</h2>
                  <p>{sectionHeadings.linksAndButtons.description}</p>
                </div>

                <div class="link-list" aria-label="普通超链接示例">
                  {inlineLinks.map((item) => (
                    <p>
                      <strong>{item.label}</strong>
                      <a href={item.href} {...externalLinkAttributes(item.href)}>
                        {item.text}
                      </a>
                    </p>
                  ))}
                </div>

                <div class="action-demo" data-action-demo>
                  <div class="action-row">
                    {actionDemos.map((item) => (
                      <button
                        class:list={["demo-button", item.tone === "primary" && "demo-button--primary"]}
                        type="button"
                        data-demo-action={item.result}
                        disabled={item.disabled}
                      >
                        {item.label}
                      </button>
                    ))}
                  </div>
                  <p data-demo-action-output role="status" aria-live="polite">按钮状态：尚未触发。</p>
                </div>
              </section>

              <section class="demo-section">
                <div class="section-heading">
                  <h2>{sectionHeadings.timelineAndMeta.title}</h2>
                  <p>{sectionHeadings.timelineAndMeta.description}</p>
                </div>

                <div class="demo-timeline" aria-label="时间线示例">
                  {timelineItems.map((item) => (
                    <section class="demo-timeline-item">
                      <time>{item.time}</time>
                      <div>
                        <h3>{item.title}</h3>
                        <p>{item.text}</p>
                      </div>
                    </section>
                  ))}
                </div>

                <dl class="sample-meta">
                  {detailRows.map(([label, value]) => (
                    <div>
                      <dt>{label}</dt>
                      <dd>{value}</dd>
                    </div>
                  ))}
                </dl>
              </section>

              <section class="demo-section">
                <div class="section-heading">
                  <h2>{sectionHeadings.longBlocks.title}</h2>
                  <p>{sectionHeadings.longBlocks.description}</p>
                </div>

                <div class="demo-grid">
                  {featureNotes.map((item) => (
                    <section class="demo-block demo-block--wide">
                      <h3>{item.title}</h3>
                      <p>{item.text}</p>
                    </section>
                  ))}
                </div>
              </section>
            </div>
          </article>
        </div>

        <div class="card-panel">
          <article class="sample-card" data-card-panel="find">
            <div class="sample-inner">
              <section class="sample-hero">
                <p class="sample-kicker">{contactHero.kicker}</p>
                <h1 class="sample-title">{contactHero.title}</h1>
                <p class="sample-copy">{contactHero.copy}</p>

                <div class="demo-toolbar" aria-label="状态示例">
                  {contactStatusChips.map((chip) => (
                    <span
                      class:list={[
                        "demo-status",
                        chip.tone === "idle" && "demo-status--idle",
                        chip.tone === "soft" && "demo-status--soft",
                      ]}
                    >
                      {chip.text}
                    </span>
                  ))}
                </div>
              </section>

              <section class="demo-section">
                <div class="section-heading">
                  <h2>{sectionHeadings.contactCards.title}</h2>
                  <p>{sectionHeadings.contactCards.description}</p>
                </div>

                <div class="contact-grid">
                  {contactLinks.map((item) =>
                    item.href ? (
                      <a
                        class="contact-card"
                        href={item.href}
                        {...externalLinkAttributes(item.href)}
                      >
                        <div class="contact-card-head">
                          <h3>{item.label}</h3>
                          <span class="contact-pill">{item.tag}</span>
                        </div>
                        <p>{item.note}</p>
                        <span class="contact-meta">{item.meta}</span>
                      </a>
                    ) : (
                      <div class="contact-card contact-card--pending">
                        <div class="contact-card-head">
                          <h3>{item.label}</h3>
                          <span class="contact-pill contact-pill--muted">{item.tag}</span>
                        </div>
                        <p>{item.note}</p>
                        <span class="contact-meta">{item.meta}</span>
                      </div>
                    ),
                  )}
                </div>
              </section>

              <section class="demo-section demo-section--split">
                <div class="preference-grid">
                  {contactPreferences.map((item) => (
                    <section class="preference-card">
                      <span>{item.value}</span>
                      <h3>{item.title}</h3>
                      <p>{item.text}</p>
                    </section>
                  ))}
                </div>

                <div class="demo-panel">
                  <h2>{contactInfoPanel.title}</h2>
                  <p>{contactInfoPanel.body}</p>
                  <ul class="demo-list">
                    {contactNotes.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
              </section>

              <section class="demo-section">
                <div class="section-heading">
                  <h2>{sectionHeadings.contactRows.title}</h2>
                  <p>{sectionHeadings.contactRows.description}</p>
                </div>

                <div class="demo-table" aria-label="联系偏好示例">
                  {contactRows.map(([label, value]) => (
                    <div>
                      <span>{label}</span>
                      <strong>{value}</strong>
                    </div>
                  ))}
                </div>
              </section>

              <section class="demo-section">
                <div class="section-heading">
                  <h2>{sectionHeadings.contactTimeline.title}</h2>
                  <p>{sectionHeadings.contactTimeline.description}</p>
                </div>

                <div class="demo-timeline" aria-label="联系流程示例">
                  {contactTimeline.map((item) => (
                    <section class="demo-timeline-item">
                      <time>{item.time}</time>
                      <div>
                        <h3>{item.title}</h3>
                        <p>{item.text}</p>
                      </div>
                    </section>
                  ))}
                </div>
              </section>

              <section class="demo-section demo-section--split">
                <div class="demo-code" aria-label="链接配置示例">
                  <div class="demo-code-head">
                    <span>{codeDemos.links.filename}</span>
                    <button type="button" data-copy-button aria-label="复制代码" aria-live="polite">复制</button>
                  </div>
                  <pre><code>{codeDemos.links.code}</code></pre>
                </div>

                <dl class="sample-meta">
                  {contactDetailRows.map(([label, value]) => (
                    <div>
                      <dt>{label}</dt>
                      <dd>{value}</dd>
                    </div>
                  ))}
                </dl>
              </section>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>
</main>

<script is:inline define:vars={{ themeConfig }}>
  (() => {
    const shell = document.querySelector("[data-home-shell]");

    if (!shell) {
      return;
    }

    const links = [...shell.querySelectorAll("[data-tab-target]")];
    const stage = shell.querySelector(".card-stage");
    const topbar = shell.querySelector(".topbar");
    const themeToggle = shell.querySelector("[data-theme-toggle]");
    const copyButtons = [...shell.querySelectorAll("[data-copy-button]")];
    const actionButtons = [...shell.querySelectorAll("[data-demo-action]")];
    const pathToState = () => location.pathname.startsWith("/find") ? "find" : "about";
    const themeStorageKey = themeConfig.storageKey;
    const topbarIdleDelay = 820;
    let topbarIdleTimer = 0;
    let pendingTabSwitch = 0;
    const darkScheme = matchMedia(themeConfig.darkQuery);
    const themeColors = themeConfig.colors;

    const getStoredTheme = () => {
      try {
        const theme = localStorage.getItem(themeStorageKey);
        return theme === "dark" || theme === "light" ? theme : null;
      } catch {
        return null;
      }
    };

    const getSystemTheme = () => darkScheme.matches ? "dark" : "light";

    const applyTheme = (theme) => {
      const activeTheme = theme === "dark" ? "dark" : "light";
      document.documentElement.dataset.theme = activeTheme;
      document.documentElement.style.colorScheme = activeTheme;
      document.querySelector("[data-theme-color]")?.setAttribute("content", themeColors[activeTheme]);
      themeToggle?.setAttribute("aria-pressed", String(activeTheme === "dark"));
      themeToggle?.setAttribute("aria-label", activeTheme === "dark" ? "切换浅色模式" : "切换深色模式");
    };

    const updatePanelHeight = (active = shell.dataset.active) => {
      const card = shell.querySelector(`[data-card-panel="${active}"]`);

      if (!stage || !card) {
        return;
      }

      const rootFontSize = Number.parseFloat(getComputedStyle(document.documentElement).fontSize) || 16;
      const panelBlockSize = card.getBoundingClientRect().height / rootFontSize;
      stage.style.setProperty("--active-panel-block-size", `${panelBlockSize}rem`);
    };

    const showTopbar = () => {
      window.clearTimeout(topbarIdleTimer);
      delete shell.dataset.topbarHidden;
    };

    const isTopbarInteractive = () => Boolean(topbar?.matches(":hover, :focus-within"));

    const setTopbarOverlapState = (isOverlapping) => {
      if (isOverlapping) {
        shell.dataset.topbarOverlap = "true";
      } else {
        delete shell.dataset.topbarOverlap;
      }
    };

    const isTopbarOverlappingCard = () => {
      const activeCard = shell.querySelector(`[data-card-panel="${shell.dataset.active}"]`);

      if (!topbar || !activeCard) {
        return false;
      }

      const topbarRect = topbar.getBoundingClientRect();
      const cardRect = activeCard.getBoundingClientRect();
      const rootFontSize = Number.parseFloat(getComputedStyle(document.documentElement).fontSize) || 16;
      const overlapPadding = rootFontSize * 0.5;

      return topbarRect.bottom > cardRect.top + overlapPadding && topbarRect.top < cardRect.bottom - overlapPadding;
    };

    const refreshTopbarOverlapState = () => {
      const isOverlapping = isTopbarOverlappingCard();
      setTopbarOverlapState(isOverlapping);
      return isOverlapping;
    };

    const updateTopbarIdleState = () => {
      if (refreshTopbarOverlapState() && !isTopbarInteractive()) {
        shell.dataset.topbarHidden = "true";
      } else {
        showTopbar();
      }
    };

    const scheduleTopbarIdleState = () => {
      window.clearTimeout(topbarIdleTimer);
      topbarIdleTimer = window.setTimeout(updateTopbarIdleState, topbarIdleDelay);
    };

    const handleScroll = () => {
      refreshTopbarOverlapState();
      showTopbar();
      scheduleTopbarIdleState();
    };

    const prefersReducedMotion = () => matchMedia("(prefers-reduced-motion: reduce)").matches;

    const waitForScrollTop = () => new Promise((resolve) => {
      if (window.scrollY <= 1 || prefersReducedMotion()) {
        window.scrollTo({ top: 0, left: 0, behavior: "auto" });
        resolve();
        return;
      }

      const startedAt = Date.now();
      const timeout = 1200;

      const check = () => {
        if (window.scrollY <= 1 || Date.now() - startedAt > timeout) {
          resolve();
          return;
        }

        requestAnimationFrame(check);
      };

      window.scrollTo({ top: 0, left: 0, behavior: "smooth" });
      requestAnimationFrame(check);
    });

    const switchAfterTop = async (next, shouldPush = false) => {
      const active = next === "find" ? "find" : "about";

      if (active === shell.dataset.active) {
        return;
      }

      const switchId = ++pendingTabSwitch;
      showTopbar();
      await waitForScrollTop();

      if (switchId !== pendingTabSwitch) {
        return;
      }

      setActive(active, shouldPush, false);
    };

    const copyText = async (text) => {
      try {
        await navigator.clipboard.writeText(text);
        return true;
      } catch {
        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.insetBlockStart = "-100vh";
        document.body.append(textarea);
        textarea.select();

        try {
          const execCopy = document["exec" + "Command"];
          return typeof execCopy === "function" && execCopy.call(document, "copy");
        } catch {
          return false;
        } finally {
          textarea.remove();
        }
      }
    };

    const selectCode = (codeElement) => {
      if (!codeElement) {
        return false;
      }

      const selection = window.getSelection();
      const range = document.createRange();
      range.selectNodeContents(codeElement);
      selection?.removeAllRanges();
      selection?.addRange(range);
      return true;
    };

    const setCopyButtonFeedback = (button, label, state) => {
      window.clearTimeout(Number(button.dataset.copyResetTimer) || 0);
      button.textContent = label;
      button.setAttribute("aria-label", label);
      button.dataset.copyState = state;
      button.dataset.copyResetTimer = String(window.setTimeout(() => {
        button.textContent = "复制";
        button.setAttribute("aria-label", "复制代码");
        delete button.dataset.copyState;
        delete button.dataset.copyResetTimer;
      }, 1400));
    };

    const setActive = (next, shouldPush = false, shouldResetScroll = false) => {
      const active = next === "find" ? "find" : "about";

      if (shouldResetScroll && active !== shell.dataset.active) {
        window.scrollTo({ top: 0, left: 0, behavior: "auto" });
      }

      showTopbar();
      updatePanelHeight(active);
      shell.dataset.active = active;

      links.forEach((link) => {
        const isCurrent = link.dataset.tabTarget === active;
        if (isCurrent) {
          link.setAttribute("aria-current", "page");
        } else {
          link.removeAttribute("aria-current");
        }
      });

      if (shouldPush) {
        const href = active === "find" ? "/find/" : "/";
        history.pushState({ active }, "", href);
      }
    };

    const queueHeightUpdate = () => {
      requestAnimationFrame(() => {
        updatePanelHeight();
        refreshTopbarOverlapState();
        scheduleTopbarIdleState();
      });
    };

    links.forEach((link) => {
      link.addEventListener("click", (event) => {
        event.preventDefault();
        switchAfterTop(link.dataset.tabTarget, true);
      });
    });

    copyButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        const codeElement = button.closest(".demo-code")?.querySelector("code");
        const code = codeElement?.textContent?.trim();

        if (!code) {
          return;
        }

        if (await copyText(code)) {
          setCopyButtonFeedback(button, "已复制", "success");
        } else if (selectCode(codeElement)) {
          setCopyButtonFeedback(button, "已选中", "selected");
        } else {
          setCopyButtonFeedback(button, "复制失败", "error");
        }
      });
    });

    actionButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const output = button.closest("[data-action-demo]")?.querySelector("[data-demo-action-output]");
        if (output) {
          output.textContent = `按钮状态：${button.dataset.demoAction}`;
        }
      });
    });

    themeToggle?.addEventListener("click", () => {
      const nextTheme = document.documentElement.dataset.theme === "dark" ? "light" : "dark";

      try {
        if (nextTheme === getSystemTheme()) {
          localStorage.removeItem(themeStorageKey);
        } else {
          localStorage.setItem(themeStorageKey, nextTheme);
        }
      } catch {
        // Theme switching should still work when storage is unavailable.
      }

      applyTheme(nextTheme);
    });

    const handleSchemeChange = () => {
      if (!getStoredTheme()) {
        applyTheme(getSystemTheme());
      }
    };

    if (typeof darkScheme.addEventListener === "function") {
      darkScheme.addEventListener("change", handleSchemeChange);
    } else {
      const addLegacySchemeListener = darkScheme[["add", "Listener"].join("")];
      if (typeof addLegacySchemeListener === "function") {
        addLegacySchemeListener.call(darkScheme, handleSchemeChange);
      }
    }

    window.addEventListener("popstate", () => {
      switchAfterTop(pathToState(), false);
    });

    window.addEventListener("scroll", handleScroll, { passive: true });
    window.addEventListener("resize", queueHeightUpdate);
    topbar?.addEventListener("pointerenter", showTopbar);
    topbar?.addEventListener("pointerleave", scheduleTopbarIdleState);
    topbar?.addEventListener("focusin", showTopbar);
    topbar?.addEventListener("focusout", scheduleTopbarIdleState);

    if ("ResizeObserver" in window) {
      const resizeObserver = new ResizeObserver(queueHeightUpdate);
      shell.querySelectorAll("[data-card-panel]").forEach((card) => resizeObserver.observe(card));
    }

    setActive(pathToState(), false);
    applyTheme(getStoredTheme() || getSystemTheme());
    document.fonts?.ready?.then(queueHeightUpdate);
    requestAnimationFrame(updateTopbarIdleState);
  })();
</script>
