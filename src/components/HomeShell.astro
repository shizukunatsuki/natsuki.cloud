              </section>

              <section class="demo-section demo-section--split">
                <div class="preference-grid">
                  {contactPreferences.map((item) => (
                    <section class="preference-card">
                      <span>{item.value}</span>
                      <h3>{item.title}</h3>
                      <p>{item.text}</p>
                    </section>
                  ))}
                </div>

                <div class="demo-panel">
                  <h2>联系说明</h2>
                  <p>
                    真实内容替换后，这里可以放联系偏好、回复节奏、合作说明或平台状态。
                    这个面板比入口卡片更像正文，用来测试复杂内容的阅读质感。
                  </p>
                  <ul class="demo-list">
                    {contactNotes.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
              </section>

              <section class="demo-section">
                <div class="section-heading">
                  <h2>联系方式表</h2>
                  <p>测试键值布局、长 URL 和不同文字长度。</p>
                </div>

                <div class="demo-table" aria-label="联系偏好示例">
                  {contactRows.map(([label, value]) => (
                    <div>
                      <span>{label}</span>
                      <strong>{value}</strong>
                    </div>
                  ))}
                </div>
              </section>

              <section class="demo-section">
                <div class="section-heading">
                  <h2>联系流程</h2>
                  <p>比关于页短一些，用来验证两张不同高度卡片之间的过渡。</p>
                </div>

                <div class="demo-timeline" aria-label="联系流程示例">
                  {contactTimeline.map((item) => (
                    <section class="demo-timeline-item">
                      <time>{item.time}</time>
                      <div>
                        <h3>{item.title}</h3>
                        <p>{item.text}</p>
                      </div>
                    </section>
                  ))}
                </div>
              </section>

              <section class="demo-section demo-section--split">
                <div class="demo-code" aria-label="链接配置示例">
                  <div class="demo-code-head">
                    <span>links.json</span>
                    <button type="button" data-copy-button>复制</button>
                  </div>
                  <pre><code>{`{
  "pixiv": "https://www.pixiv.net/users/99990012",
  "email": "hello@natsuki.cloud",
  "status": "soft contact"
}`}</code></pre>
                </div>

                <dl class="sample-meta">
                  <div>
                    <dt>优先级</dt>
                    <dd>Email > Pixiv > 其他平台</dd>
                  </div>
                  <div>
                    <dt>响应</dt>
                    <dd>普通留言不保证即时回复</dd>
                  </div>
                  <div>
                    <dt>长文本</dt>
                    <dd>long-link-and-mixed-content-demo</dd>
                  </div>
                </dl>
              </section>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>
</main>

<script is:inline>
  (() => {
    const shell = document.querySelector("[data-home-shell]");

    if (!shell) {
      return;
    }

    const links = [...shell.querySelectorAll("[data-tab-target]")];
    const stage = shell.querySelector(".card-stage");
    const topbar = shell.querySelector(".topbar");
    const themeToggle = shell.querySelector("[data-theme-toggle]");
    const copyButtons = [...shell.querySelectorAll("[data-copy-button]")];
    const actionButtons = [...shell.querySelectorAll("[data-demo-action]")];
    const pathToState = () => location.pathname.startsWith("/find") ? "find" : "about";
    const themeStorageKey = "natsuki-theme";
    const topbarIdleDelay = 820;
    let topbarIdleTimer = 0;
    const darkScheme = matchMedia("(prefers-color-scheme: dark)");
    const themeColors = {
      light: "#fff4f8",
      dark: "#17111f",
    };

    const getStoredTheme = () => {
      try {
        const theme = localStorage.getItem(themeStorageKey);
        return theme === "dark" || theme === "light" ? theme : null;
      } catch {
        return null;
      }
    };

    const getSystemTheme = () => darkScheme.matches ? "dark" : "light";

    const applyTheme = (theme) => {
      const activeTheme = theme === "dark" ? "dark" : "light";
      document.documentElement.dataset.theme = activeTheme;
      document.documentElement.style.colorScheme = activeTheme;
      document.querySelector("[data-theme-color]")?.setAttribute("content", themeColors[activeTheme]);
      themeToggle?.setAttribute("aria-pressed", String(activeTheme === "dark"));
      themeToggle?.setAttribute("aria-label", activeTheme === "dark" ? "切换浅色模式" : "切换深色模式");
    };

    const updatePanelHeight = (active = shell.dataset.active) => {
      const card = shell.querySelector(`[data-card-panel="${active}"]`);

      if (!stage || !card) {
        return;
      }

      const rootFontSize = Number.parseFloat(getComputedStyle(document.documentElement).fontSize) || 16;
      const panelBlockSize = card.getBoundingClientRect().height / rootFontSize;
      stage.style.setProperty("--active-panel-block-size", `${panelBlockSize}rem`);
    };

    const showTopbar = () => {
      window.clearTimeout(topbarIdleTimer);
      delete shell.dataset.topbarHidden;
    };

    const isTopbarInteractive = () => Boolean(topbar?.matches(":hover, :focus-within"));

    const setTopbarOverlapState = (isOverlapping) => {
      if (isOverlapping) {
        shell.dataset.topbarOverlap = "true";
      } else {
        delete shell.dataset.topbarOverlap;
      }
    };

    const isTopbarOverlappingCard = () => {
      const activeCard = shell.querySelector(`[data-card-panel="${shell.dataset.active}"]`);

      if (!topbar || !activeCard) {
        return false;
      }

      const topbarRect = topbar.getBoundingClientRect();
      const cardRect = activeCard.getBoundingClientRect();
      const rootFontSize = Number.parseFloat(getComputedStyle(document.documentElement).fontSize) || 16;
      const overlapPadding = rootFontSize * 0.5;

      return topbarRect.bottom > cardRect.top + overlapPadding && topbarRect.top < cardRect.bottom - overlapPadding;
    };

    const refreshTopbarOverlapState = () => {
      const isOverlapping = isTopbarOverlappingCard();
      setTopbarOverlapState(isOverlapping);
      return isOverlapping;
    };

    const updateTopbarIdleState = () => {
      if (refreshTopbarOverlapState() && !isTopbarInteractive()) {
        shell.dataset.topbarHidden = "true";
      } else {
        showTopbar();
      }
    };

    const scheduleTopbarIdleState = () => {
      window.clearTimeout(topbarIdleTimer);
      topbarIdleTimer = window.setTimeout(updateTopbarIdleState, topbarIdleDelay);
    };

    const handleScroll = () => {
      refreshTopbarOverlapState();
      showTopbar();
      scheduleTopbarIdleState();
    };

    const copyText = async (text) => {
      try {
        await navigator.clipboard.writeText(text);
        return true;
      } catch {
        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.insetBlockStart = "-100vh";
        document.body.append(textarea);
        textarea.select();

        try {
          const execCopy = document["exec" + "Command"];
          return typeof execCopy === "function" && execCopy.call(document, "copy");
        } catch {
          return false;
        } finally {
          textarea.remove();
        }
      }
    };

    const selectCode = (codeElement) => {
      if (!codeElement) {
        return false;
      }

      const selection = window.getSelection();
      const range = document.createRange();
      range.selectNodeContents(codeElement);
      selection?.removeAllRanges();
      selection?.addRange(range);
      return true;
    };

    const setActive = (next, shouldPush = false, shouldResetScroll = false) => {
      const active = next === "find" ? "find" : "about";

      if (shouldResetScroll && active !== shell.dataset.active) {
        window.scrollTo({ top: 0, left: 0, behavior: "auto" });
      }

      showTopbar();
      updatePanelHeight(active);
      shell.dataset.active = active;

      links.forEach((link) => {
        const isCurrent = link.dataset.tabTarget === active;
        if (isCurrent) {
          link.setAttribute("aria-current", "page");
        } else {
          link.removeAttribute("aria-current");
        }
      });

      if (shouldPush) {
        const href = active === "find" ? "/find/" : "/";
        history.pushState({ active }, "", href);
      }
    };

    const queueHeightUpdate = () => {
      requestAnimationFrame(() => {
        updatePanelHeight();
        refreshTopbarOverlapState();
        scheduleTopbarIdleState();
      });
    };

    links.forEach((link) => {
      link.addEventListener("click", (event) => {
        event.preventDefault();
        setActive(link.dataset.tabTarget, true, true);
      });
    });

    copyButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        const codeElement = button.closest(".demo-code")?.querySelector("code");
        const code = codeElement?.textContent?.trim();

        if (!code) {
          return;
        }

        if (await copyText(code)) {
          button.textContent = "已复制";
        } else {
          button.textContent = selectCode(codeElement) ? "已选中" : "复制失败";
        }

        window.setTimeout(() => {
          button.textContent = "复制";
        }, 1400);
      });
    });

    actionButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const output = button.closest("[data-action-demo]")?.querySelector("[data-demo-action-output]");
        if (output) {
          output.textContent = `按钮状态：${button.dataset.demoAction}`;
        }
      });
    });

    themeToggle?.addEventListener("click", () => {
      const nextTheme = document.documentElement.dataset.theme === "dark" ? "light" : "dark";

      try {
        if (nextTheme === getSystemTheme()) {
          localStorage.removeItem(themeStorageKey);
        } else {
          localStorage.setItem(themeStorageKey, nextTheme);
        }
      } catch {
        // Theme switching should still work when storage is unavailable.
      }

      applyTheme(nextTheme);
    });

    darkScheme.addEventListener("change", () => {
      if (!getStoredTheme()) {
        applyTheme(getSystemTheme());
      }
    });

    window.addEventListener("popstate", () => {
      setActive(pathToState(), false, true);
    });

    window.addEventListener("scroll", handleScroll, { passive: true });
    window.addEventListener("resize", queueHeightUpdate);
    topbar?.addEventListener("pointerenter", showTopbar);
    topbar?.addEventListener("pointerleave", scheduleTopbarIdleState);
    topbar?.addEventListener("focusin", showTopbar);
    topbar?.addEventListener("focusout", scheduleTopbarIdleState);

    if ("ResizeObserver" in window) {
      const resizeObserver = new ResizeObserver(queueHeightUpdate);
      shell.querySelectorAll("[data-card-panel]").forEach((card) => resizeObserver.observe(card));
    }

    setActive(pathToState(), false);
    applyTheme(getStoredTheme() || getSystemTheme());
    document.fonts?.ready?.then(queueHeightUpdate);
    requestAnimationFrame(updateTopbarIdleState);
  })();
</script>
