const inlineLinks = [
  {
    label: "内部链接示例",
    href: "/find/",
    text: "跳转到找到奈月，用来测试普通文本链接在正文中的样式。",
  },
  {
    label: "外部链接示例",
    href: "https://www.pixiv.net/users/99990012",
