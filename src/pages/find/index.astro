---
import BaseLayout from "@/layouts/BaseLayout.astro";

const contacts = [
  {
    label: "Pixiv",
    href: "https://www.pixiv.net/users/99990012",
    note: "插画与投稿入口",
  },
  {
    label: "Email",
    href: "mailto:hello@natsuki.cloud",
    note: "商务、合作或正式联系",
  },
  {
    label: "X / Twitter",
    note: "待补充",
  },
  {
    label: "Bilibili",
    note: "待补充",
  },
];

const links = [
  { href: "/", label: "关于奈月", key: "about", current: false },
  { href: "/find/", label: "找到奈月", key: "find", current: true },
];
---

<BaseLayout title="找到奈月 | natsuki.cloud" description="奈月的社交媒体和联系方式聚合页。">
  <main class="kawaii-shell page-shell">
    <header class="topbar">
      <a class="moon-link" href="/" aria-label="返回首页">
        <svg class="moon-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M19.5 14.5A8.5 8.5 0 0 1 9.5 4.5a8.5 8.5 0 1 0 10 10Z" />
        </svg>
      </a>
      <nav class="topnav" data-route-nav data-active="find">
        <span class="topnav-indicator" aria-hidden="true"></span>
        {links.map((link) => (
          <a
            href={link.href}
            data-nav-target={link.key}
            aria-current={link.current ? "page" : undefined}
            onclick="return window.natsukiRouteClick(event, this)"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </header>

    <section class="intro-stage">
      <article class="sample-card">
        <div class="sample-inner">
          <p class="sample-kicker">找到奈月 / contact hub</p>
          <h1 class="sample-title">联系入口</h1>
          <p class="sample-copy">
            这里集中放社交媒体和联系方式。优先联系邮箱和 Pixiv，其他平台后续补齐后也会放在这里统一管理。
          </p>

          <div class="contact-grid">
            {contacts.map((item) =>
              item.href ? (
                <a
                  class="contact-card"
                  href={item.href}
                  target={item.href.startsWith("http") ? "_blank" : undefined}
                  rel={item.href.startsWith("http") ? "noreferrer" : undefined}
                >
                  <div class="contact-card-head">
                    <h2>{item.label}</h2>
                    <span class="contact-pill">
                      入口
                    </span>
                  </div>
                  <p>{item.note}</p>
                </a>
              ) : (
                <div class="contact-card contact-card--pending">
                  <div class="contact-card-head">
                    <h2>{item.label}</h2>
                    <span class="contact-pill contact-pill--muted">
                      待补充
                    </span>
                  </div>
                  <p>{item.note}</p>
                </div>
              ),
            )}
          </div>

          <div class="sample-card-accent">
            <span class="sample-chip">社交媒体聚合</span>
            <span class="sample-chip">合作联系</span>
            <span class="sample-chip">统一入口</span>
          </div>
        </div>
      </article>
    </section>
  </main>
</BaseLayout>
